{
  "version": "0.1",
  "id": "raster-basemap-example",
  "view": {
    "mode": "map2d",
    "center": [120.15, 30.28],
    "zoom": 10
  },
  "sources": {
    "local-raster": {
      "type": "raster",
      "tiles": ["./tiles/{z}/{x}/{y}.png"],
      "tileSize": 256,
      "attribution": "Local raster tiles"
    },
    "city-boundary": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "properties": {
              "name": "demo-boundary"
            },
            "geometry": {
              "type": "Polygon",
              "coordinates": [[[120.02, 30.18], [120.3, 30.18], [120.3, 30.38], [120.02, 30.38], [120.02, 30.18]]]
            }
          }
        ]
      }
    }
  },
  "layers": [
    {
      "id": "basemap-raster",
      "type": "raster",
      "source": "local-raster",
      "paint": {
        "raster-opacity": 0.92
      }
    },
    {
      "id": "boundary-line",
      "type": "line",
      "source": "city-boundary",
      "paint": {
        "line-color": "#0f766e",
        "line-width": 2
      }
    }
  ]
}
