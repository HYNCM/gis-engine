{
  "name": "gis-engine-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:schema": "pnpm --filter @gis-engine/engine build:schema && pnpm --filter @gis-engine/scene3d build && pnpm --filter @gis-engine/ai build:schema",
    "schema:diff": "node scripts/schema-diff.mjs",
    "test": "pnpm test:schema && pnpm test:schema-sync && pnpm test:commands && pnpm test:patch && pnpm test:runtime && pnpm test:adapter && pnpm test:ai && pnpm test:cli && pnpm test:examples && pnpm test:docs && pnpm test:agent-framework && pnpm test:resources && pnpm test:perf:smoke && pnpm test:snapshot:smoke",
    "test:schema": "vitest run tests/schema/schema-fixtures.test.ts tests/schema/expression-validator.test.ts tests/schema/resource-policy.test.ts tests/schema/cloud-native-policy.test.ts",
    "test:schema-sync": "vitest run tests/schema-sync",
    "test:commands": "vitest run tests/commands",
    "test:patch": "vitest run tests/patch",
    "test:runtime": "vitest run tests/runtime",
    "test:adapter": "vitest run tests/adapter",
    "test:examples": "vitest run tests/examples",
    "test:studio": "vitest run tests/studio",
    "test:docs": "vitest run tests/docs",
    "test:agent-framework": "vitest run tests/framework",
    "test:snapshot": "pnpm test:snapshot:smoke && pnpm test:snapshot:visual",
    "test:snapshot:smoke": "vitest run tests/snapshot/smoke",
    "test:snapshot:visual": "playwright test tests/snapshot/visual",
    "test:snapshot:update": "GIS_ENGINE_REQUIRE_VISUAL_SNAPSHOT=1 SNAPSHOT_UPDATE=1 pnpm test:snapshot:visual",
    "test:ai": "vitest run tests/ai",
    "test:cli": "vitest run tests/cli",
    "test:qa-matrix": "vitest run tests/examples/qa-matrix.test.ts",
    "test:perf:smoke": "vitest run tests/perf",
    "test:perf:trend": "vitest run tests/perf/perf-trend-ledger.test.ts",
    "test:perf:ci": "node scripts/perf-trend.mjs --ci --json --budget-multiplier 2",
    "test:perf:nightly": "vitest run tests/nightly-perf",
    "test:resources": "vitest run tests/resources",
    "test:e2e": "pnpm test:e2e:node && pnpm test:e2e:browser",
    "test:e2e:node": "vitest run tests/e2e/render-pipeline.test.ts",
    "test:e2e:browser": "playwright test tests/e2e/render-pipeline.spec.ts",
    "test:release:scene3d": "vitest run tests/snapshot/smoke/scene3d-release-visual-gate.test.ts",
    "test:release:rc": "pnpm build:schema && pnpm check && pnpm test:snapshot:visual",
    "test:release:strict": "pnpm build:schema && pnpm check && GIS_ENGINE_REQUIRE_VISUAL_SNAPSHOT=1 pnpm test:snapshot:visual",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "check": "pnpm build && pnpm test && pnpm test:studio",
    "example:basic-geojson": "tsx examples/basic-geojson/validate.ts",
    "example:ai-map-workbench": "pnpm build:schema && node examples/ai-map-workbench/server.mjs",
    "studio:dev": "pnpm --filter @gis-engine/studio dev",
    "studio:build": "pnpm --filter @gis-engine/studio build",
    "studio:server": "node apps/studio/server/index.mjs",
    "agent": "node scripts/agent-runner.mjs",
    "agent:daily": "node scripts/agent-runner.mjs all --daily",
    "agent:weekly": "node scripts/agent-runner.mjs all --weekly",
    "agent:orchestrator": "node scripts/agent-runner.mjs orchestrator",
    "agent:product": "node scripts/agent-runner.mjs product",
    "agent:quality": "node scripts/agent-runner.mjs quality",
    "agent:builder": "node scripts/agent-runner.mjs builder",
    "agent:docs": "node scripts/agent-runner.mjs docs",
    "agent:handoff": "node scripts/handoff-ledger.mjs",
    "agent:dashboard": "node scripts/dashboard-generator.mjs",
    "agent:sla": "node scripts/sla-checker.mjs",
    "gate:plan": "node scripts/gate-plan.mjs",
    "gate:run": "node scripts/gate-plan.mjs --run",
    "issues:snapshot": "node scripts/issues-snapshot.mjs",
    "reports:retention": "node scripts/report-retention.mjs",
    "docs:generate": "node scripts/doc-generator.mjs",
    "docs:api": "node scripts/build-api-docs.mjs",
    "docs:changelog": "node scripts/doc-generator.mjs changelog",
    "docs:features": "node scripts/doc-generator.mjs features",
    "docs:links": "node scripts/doc-generator.mjs links",
    "docs:dev": "pnpm docs:api && cd docs/website && pnpm docs:dev",
    "docs:build": "pnpm docs:api && cd docs/website && pnpm docs:build",
    "docs:preview": "cd docs/website && pnpm docs:preview",
    "size:check": "du -sk packages/*/dist | sort -rn",
    "smoke:first-run": "node scripts/first-run-acceptance.mjs",
    "smoke:cli-install": "node scripts/cli-install-smoke.mjs",
    "smoke:provider": "node scripts/provider-smoke.mjs",
    "build:cdn": "node scripts/build-cdn.mjs",
    "publish:dry": "pnpm build && pnpm --filter @gis-engine/engine publish --dry-run --no-git-checks && pnpm --filter @gis-engine/scene3d publish --dry-run --no-git-checks && pnpm --filter @gis-engine/ai publish --dry-run --no-git-checks && pnpm --filter @gis-engine/cli publish --dry-run --no-git-checks",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "release:publish": "node scripts/publish-ga-packages.mjs",
    "release:publish:dry": "node scripts/publish-ga-packages.mjs --dry-run",
    "knip": "knip",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.56.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "ajv": "^8.17.0",
    "husky": "^9.1.7",
    "knip": "^6.16.0",
    "maplibre-gl": "^5.0.0 || ^6.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
