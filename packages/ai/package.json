{
  "name": "@gis-engine/ai",
  "version": "1.5.0",
  "description": "AI and MCP tools for validating, editing, explaining, snapshotting, and exporting GIS Engine MapSpec documents.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "gis-engine-mcp": "./dist/mcp/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HYNCM/gis-engine.git",
    "directory": "packages/ai"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "import": "./dist/tools/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:schema": "pnpm build && node scripts/build-schema.mjs",
    "start:mcp": "node dist/mcp/server.js"
  },
  "dependencies": {
    "@gis-engine/engine": "workspace:*",
    "@gis-engine/scene3d": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": [
    "gis",
    "maps",
    "ai",
    "mcp",
    "model-context-protocol",
    "map-spec",
    "map-editing",
    "structured-output"
  ]
}
