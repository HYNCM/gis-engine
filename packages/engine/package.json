{
  "name": "@gis-engine/engine",
  "version": "1.4.0",
  "description": "AI-native MapSpec runtime, command system, diagnostics, snapshots, and renderer adapters.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HYNCM/gis-engine.git",
    "directory": "packages/engine"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:schema": "tsc -p tsconfig.json && node dist/scripts/build-schema.js"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "ajv": "^8.17.0"
  },
  "peerDependencies": {
    "maplibre-gl": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "gis",
    "maps",
    "map-spec",
    "map-editing",
    "command-pattern",
    "structured-diagnostics",
    "schema-first",
    "typebox",
    "deterministic",
    "renderer-adapter"
  ]
}
