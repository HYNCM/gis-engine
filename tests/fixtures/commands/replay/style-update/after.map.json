{
  "version": "0.1",
  "id": "style-update",
  "revision": "2",
  "view": {
    "mode": "map2d",
    "center": [120.15, 30.28],
    "zoom": 11
  },
  "sources": {
    "districts": {
      "type": "geojson",
      "data": "./data/districts.geojson"
    }
  },
  "layers": [
    {
      "id": "district-fill",
      "type": "fill",
