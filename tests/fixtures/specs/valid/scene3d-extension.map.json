{
  "version": "0.1",
  "id": "scene3d-extension",
  "revision": "1",
  "view": {
    "mode": "map2d",
    "center": [120.15, 30.28],
    "zoom": 11
  },
  "sources": {
    "pois": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": []
      }
    }
  },
  "layers": [
    {
      "id": "poi-circles",
      "type": "circle",
      "source": "pois",
      "paint": {
        "circle-radius": 6,
        "circle-color": "#2563eb"
      }
    }
  ],
  "extensions": {
    "scene3d": {
      "camera": {
        "position": [120.15, 30.28, 1200],
        "target": [120.15, 30.28, 0],
        "up": [0, 0, 1],
        "fov": 45
      },
      "lights": [
        {
          "type": "directional",
          "direction": [0.3, 0.5, -1],
          "intensity": 0.8
        }
      ],
      "depth": {
        "enabled": true,
        "clearColor": "#e2e8f0"
      },
      "terrain": {
        "type": "none"
      },
      "tilesets": []
    }
  }
}
